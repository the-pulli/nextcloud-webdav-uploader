{
    "name": "pulli/nextcloud-webdav-uploader",
    "description": "Upload files to Nextcloud over WebDAV from the command line, with chunked uploads, checksum verification, and skip-if-unchanged support.",
    "keywords": [
        "pulli",
        "nextcloud",
        "webdav",
        "upload"
    ],
    "homepage": "https://github.com/the-pulli/nextcloud-webdav-uploader",
    "license": "MIT",
    "authors": [
        {
            "name": "PuLLi",
            "email": "the@pulli.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.9||^8.0",
        "symfony/console": "^7.2||^8.0",
        "symfony/finder": "^7.2||^8.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pulli\\NextcloudWebdavUploader\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pulli\\NextcloudWebdavUploader\\Tests\\": "tests"
        }
    },
    "bin": [
        "nextcloud-webdav-uploader"
    ],
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
